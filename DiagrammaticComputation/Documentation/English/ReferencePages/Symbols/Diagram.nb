Cell["Create a diagram with two output and three input ports:", "ExampleText",
 CellChangeTimes->{{3.933753905384884*^9, 3.9337539187248173`*^9}},
 CellID->579251261,ExpressionUUID->"336dfe0b-fcce-404d-84fd-7ead5ab604d4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Diagram", "[", 
  RowBox[{"\"\<A\>\"", ",", 
   RowBox[{"{", 
    RowBox[{"a", ",", "b"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"c", ",", "d", ",", "e"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[38]:=",
 CellID->1511260990,ExpressionUUID->"88015f86-d6ec-443f-a107-6f7fe51690e2"],

Cell[BoxData[
 GraphicsBox[
  NamespaceBox["Diagram",
   DynamicModuleBox[{Typeset`d = HoldComplete[
     Wolfram`DiagrammaticComputation`Diagram`Diagram[<|
      "DiagramOptions" -> {
